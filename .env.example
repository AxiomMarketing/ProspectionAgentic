# Database
DATABASE_URL=postgresql://prospection:changeme@localhost:5432/prospection_dev

# Redis
REDIS_URL=redis://:changeme@localhost:6379

# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-xxx
