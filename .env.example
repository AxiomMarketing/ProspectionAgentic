# ============================================
# ProspectionAgentic — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required vars are marked with [REQUIRED]
# Optional vars have defaults or graceful fallbacks

# ══════════════════════════════════════════════
#                  SOCLE COMMUN
# ══════════════════════════════════════════════

# ──────────── Application ────────────
NODE_ENV=development                          # development | production | test
APP_PORT=3000                                 # [REQUIRED] Server port
ALLOWED_ORIGINS=http://localhost:5173          # Comma-separated CORS origins
LOG_LEVEL=debug                               # fatal | error | warn | info | debug | trace

# ──────────── Database (PostgreSQL) ────────────
DATABASE_URL=postgresql://prospection:changeme@localhost:5433/prospection_dev  # [REQUIRED]
# Production: postgresql://prospection:STRONG_PASSWORD@postgres:5432/prospection_prod
# Add ?connection_limit=20&pool_timeout=10 for production

# ──────────── Redis + BullMQ ────────────
REDIS_URL=redis://:changeme@localhost:6381    # [REQUIRED] Full Redis URL
REDIS_HOST=localhost                          # Alternative: individual connection params
REDIS_PORT=6381                               # Default: 6379 (dev uses 6381)
REDIS_PASSWORD=changeme                       # Redis AUTH password

# ──────────── Claude API (Anthropic) ────────────
ANTHROPIC_API_KEY=                            # Optional in dev (falls back to mock adapter)
# Get your key at: https://console.anthropic.com/settings/keys
LLM_MONTHLY_BUDGET_EUR=500                    # Monthly spending limit in EUR
LLM_DAILY_BUDGET_EUR=25                       # Daily spending limit in EUR

# ──────────── JWT Authentication ────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_OF_AT_LEAST_64_CHARACTERS_FOR_SECURITY  # [REQUIRED]
# Generate: openssl rand -hex 32
JWT_EXPIRATION=15m                            # Access token lifetime
JWT_REFRESH_EXPIRATION=7d                     # Refresh token lifetime

# ──────────── Internal API Keys ────────────
INTERNAL_API_KEYS=dev-api-key-1,dev-api-key-2 # Comma-separated keys for service-to-service auth

# ──────────── Langfuse (LLM Observability) ────────────
LANGFUSE_PUBLIC_KEY=                          # Optional — from Langfuse dashboard
LANGFUSE_SECRET_KEY=                          # Optional
LANGFUSE_HOST=                                # Optional — e.g., https://langfuse.yourdomain.com

# ──────────── Slack Notifications ────────────
SLACK_WEBHOOK_URL=                            # Optional — Slack incoming webhook URL
SLACK_CRITICAL_WEBHOOK_URL=                   # Optional — Separate webhook for CRITICAL alerts (falls back to SLACK_WEBHOOK_URL)

# ──────────── Domain & Security ────────────
DOMAIN=localhost                              # Production domain for Caddy reverse proxy
ADMIN_IP=127.0.0.1                            # [REQUIRED in prod] Your IP for admin panel access

# ──────────── Docker Dev Ports ────────────
# PostgreSQL: 5433 (avoids conflict with host pg on 5432)
# Redis: 6381 (avoids conflict with host redis on 6379/6380)

# ══════════════════════════════════════════════
#          AGENT 1 — VEILLEUR
# ══════════════════════════════════════════════

# ──────────── 1a LinkedIn — Signaux business ────────────

# Netrows API — Profils LinkedIn, employés, changements de poste
# Inscription : https://netrows.com — 99€/mois (40K crédits)
NETROWS_API_KEY=
NETROWS_API_URL=https://api.netrows.com/v1

# SignalsAPI — Job postings, hiring velocity, headcount changes
# Inscription : https://signalsapi.com — 99$/mois (Starter)
SIGNALSAPI_KEY=
SIGNALSAPI_BASE_URL=https://api.signalsapi.com/v1

# Hunter.io — Email finder (partagé avec Agent 2)
# Inscription : https://hunter.io — 49€/mois (1500 lookups)
HUNTER_API_KEY=

# n8n — RSS LinkedIn pages → webhooks (self-hosted, 0€)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/

# RSS Levées de fonds (gratuit, pas de clé)
RSS_CRUNCHBASE_URL=https://news.crunchbase.com/feed/
RSS_MADDYNESS_URL=https://www.maddyness.com/feed/
RSS_BPI_URL=https://bigmedia.bpifrance.fr/feed/
RSS_ECHOS_STARTUPS_URL=https://start.lesechos.fr/feed/

# ──────────── 1b Marchés Publics — APIs gratuites ────────────

# BOAMP — Avis de marchés publics (gratuit, pas d'auth)
BOAMP_API_URL=https://boamp-datadila.opendatasoft.com/api/explore/v2.1
BOAMP_PAGE_SIZE=100

# DECP — Marchés attribués, veille concurrentielle (gratuit)
DECP_API_URL=https://data.economie.gouv.fr/api/explore/v2.1/catalog/datasets/decp-v3-marches-valides

# APProch — Projets d'achats futurs AVANT publication AO (gratuit)
APPROCH_API_URL=https://data.economie.gouv.fr/api/explore/v2.1/catalog/datasets/projets-dachats-publics

# ──────────── 1c Veille Web — Audit technique ────────────

# PageSpeed Insights — Fallback Lighthouse CLI (25K req/jour gratuites)
# Console : https://console.cloud.google.com/apis/credentials
PAGESPEED_API_KEY=

# Config scan batch nocturne
LIGHTHOUSE_MAX_CONCURRENT=5                   # Workers parallèles (défaut: 5)
LIGHTHOUSE_TIMEOUT_MS=60000                   # Timeout par audit en ms (défaut: 60s)
WEBSCAN_BATCH_SIZE=500                        # Sites max par nuit
WEBSCAN_MIN_SCORE=30                          # Score min pour générer un lead
WEBSCAN_CACHE_TTL_HOURS=48                    # Durée avant re-scan d'un site

# Lighthouse CLI + Wappalyzer + axe-core + Pa11y + Playwright
# → npm packages, pas de clé API nécessaire

# --- Sources de sites à scanner ---

# INSEE SIRENE — Filtre par code NAF + département (gratuit)
# Inscription : https://api.insee.fr
SIRENE_API_TOKEN=

# Google Maps via Outscraper — Scraping par catégorie + zone géo
# Inscription : https://outscraper.com — ~$3/1K résultats
OUTSCRAPER_API_KEY=

# SerpAPI — Google Search par activité + ville
# Inscription : https://serpapi.com — $50/mois
SERPAPI_KEY=

# Pappers Alertes — Nouvelles créations d'entreprises
# Inscription : https://www.pappers.fr/api — 60€/mois
PAPPERS_API_KEY=

# SocieteInfo — Enrichissement batch entreprises FR
# Inscription : https://societeinfo.com/api — 39€/mois
SOCIETEINFO_API_KEY=

# BODACC Créations — Entreprises créées < 6 mois (gratuit, open data)
# Pas de clé — API publique

# ──────────── 1d Job Boards — Signaux emploi ────────────

# Apify — LinkedIn Jobs + WTTJ + HelloWork + Pages Jaunes scrapers
# Inscription : https://apify.com — 49$/mois (Starter)
APIFY_API_TOKEN=
APIFY_LINKEDIN_JOBS_ACTOR=                    # ID actor LinkedIn Jobs
APIFY_WTTJ_ACTOR=                             # ID actor Welcome to the Jungle
APIFY_HELLOWORK_ACTOR=                        # ID actor HelloWork
APIFY_PAGESJAUNES_ACTOR=                      # ID actor Pages Jaunes (pour 1c)

# HasData — Indeed scraping API
# Inscription : https://hasdata.com — 50$/mois (5000 req)
HASDATA_API_KEY=
HASDATA_BASE_URL=https://api.hasdata.com/scrape/indeed

# WhoisFreaks — Lookup domaines
# Inscription : https://whoisfreaks.com — 29$/mois
WHOISFREAKS_API_KEY=

# ──────────── Master Veilleur — Orchestration ────────────

# Feature flags (activer/désactiver chaque sous-agent)
VEILLEUR_ENABLED=true
VEILLEUR_LINKEDIN_ENABLED=true
VEILLEUR_MARCHES_ENABLED=true
VEILLEUR_WEB_ENABLED=true
VEILLEUR_JOBBOARDS_ENABLED=true

# Crons (format crontab)
VEILLEUR_LINKEDIN_CRON=0 7,12,18,23 * * *    # 4 passes/jour
VEILLEUR_MARCHES_CRON=0 6,14 * * *           # 2 passes/jour
VEILLEUR_WEB_CRON=0 2 * * *                  # Batch nocturne
VEILLEUR_JOBBOARDS_CRON=0 6 * * *            # 1 passe/jour
VEILLEUR_CONSOLIDATION_CRON=0 8,15,21 * * *  # 3 consolidations/jour
VEILLEUR_REPORT_CRON=30 23 * * *             # Rapport quotidien

# Pre-scoring seuils
VEILLEUR_HOT_THRESHOLD=60                     # Score min → HOT
VEILLEUR_WARM_THRESHOLD=40                    # Score min → WARM

# ══════════════════════════════════════════════
#          AGENT 2 — ENRICHISSEUR
# ══════════════════════════════════════════════

# ──────────── 2a Contact — Email finding + vérification ────────────

# Reacher — Email verification self-hosted (0€)
REACHER_URL=http://localhost:8080
REACHER_MAX_CONCURRENT=5                      # Max parallel SMTP verifications
REACHER_TIMEOUT_MS=30000                      # Timeout per verification (ms)
REACHER_MAX_REQUESTS_PER_DAY=500              # Daily limit (protect IP reputation)

# Hunter.io — Email finder fallback (partagé avec Agent 1a)
# Inscription : https://hunter.io — 49€/mois (déjà déclaré dans Agent 1)
# HUNTER_API_KEY déjà déclaré plus haut

# ──────────── 2b Entreprise — Données légales + financières ────────────

# INSEE SIRENE → déjà déclaré dans Agent 1c (SIRENE_API_TOKEN)
# INPI/RNE → déclaré ci-dessous
# Pappers → déjà déclaré dans Agent 1c (PAPPERS_API_KEY)
# SocieteInfo → déjà déclaré dans Agent 1c (SOCIETEINFO_API_KEY)
# BODACC → API publique, pas de clé

# ──────────── 2c Technique — Audit web ────────────
# Réutilise les mêmes outils que Agent 1c (Lighthouse, Wappalyzer, axe-core)
# Pas de variable d'env supplémentaire

# ──────────── Master Enrichisseur — Orchestration ────────────
ENRICHISSEUR_ENABLED=true
ENRICHISSEUR_GLOBAL_TIMEOUT_MS=180000         # 3 min max par lead
ENRICHISSEUR_CONCURRENCY=5                    # Leads enrichis en parallèle

# ══════════════════════════════════════════════
#          AGENT 3 — SCOREUR
# ══════════════════════════════════════════════
# Calcul 100% local — pas de clé API, pas de coût
SCOREUR_ENABLED=true
SCOREUR_MODEL_VERSION=2.0.0              # Version du modèle de scoring
SCOREUR_HOT_THRESHOLD=75                 # Score min → HOT (A/B/C)
SCOREUR_WARM_THRESHOLD=50                # Score min → WARM
SCOREUR_COLD_THRESHOLD=25                # Score min → COLD

# ══════════════════════════════════════════════
#          AGENT 4 — RÉDACTEUR
# ══════════════════════════════════════════════
# Utilise ANTHROPIC_API_KEY du socle commun (Claude Sonnet 4)
REDACTEUR_ENABLED=true
REDACTEUR_MAX_TOKENS=600                      # Max tokens par génération email
REDACTEUR_TEMPERATURE=0.7                     # Température LLM par défaut
REDACTEUR_RETRY_TEMPERATURE=0.5               # Température retry après validation fail
REDACTEUR_REQUIRE_APPROVAL=false              # true → messages attendent approbation humaine

# ──────────── Identité expéditeur (LCEN / anti-spam) ────────────
AXIOM_SIRET=XXX XXX XXX XXXXX                 # SIRET pour mentions légales emails
AXIOM_ADDRESS=Adresse du siège social         # Adresse postale pour footer email
UNSUBSCRIBE_BASE_URL=https://axiom-marketing.fr/unsubscribe  # Base URL lien désinscription

# ══════════════════════════════════════════════
#          AGENT 5 — SUIVEUR
# ══════════════════════════════════════════════
SUIVEUR_ENABLED=true

# Mailgun webhook signing key — used for HMAC-SHA256 signature verification
# Find in: Mailgun Dashboard → Sending → Webhooks → Webhook signing key
# [REQUIRED] — webhooks will be rejected if not set (fail-closed)
MAILGUN_WEBHOOK_SIGNING_KEY=
SUIVEUR_MAX_EMAILS_PER_DAY=100               # Limite quotidienne envois (Gmail safe: 100)
SUIVEUR_MIN_HOURS_BETWEEN_STEPS=48           # Minimum entre 2 steps même prospect
SUIVEUR_BUSINESS_HOURS_START=8               # Heure début envoi
SUIVEUR_BUSINESS_HOURS_END=18                # Heure fin envoi
SUIVEUR_DEFAULT_TIMEZONE=Europe/Paris        # Timezone par défaut prospects

# Gmail — Envoi d'emails (OAuth2)
# Setup : https://developers.google.com/gmail/api/quickstart/nodejs
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=                                   # Adresse Gmail d'envoi

# ──────────── 2b Entreprise — Données légales ────────────

# INSEE SIRENE → déjà déclaré dans 1c (SIRENE_API_TOKEN)

# INPI / RNE — Registre national des entreprises
# Inscription : https://data.inpi.fr
INPI_API_URL=https://data.inpi.fr/api
INPI_USERNAME=
INPI_PASSWORD=

# BODACC — Créations, radiations, ventes (gratuit)
# Pas de clé — API publique

# Pappers → déjà déclaré dans 1c (PAPPERS_API_KEY)
# SocieteInfo → déjà déclaré dans 1c (SOCIETEINFO_API_KEY)

# ══════════════════════════════════════════════
#     AGENTS 3-10 — À compléter progressivement
# ══════════════════════════════════════════════
# Agent 3 (Scoreur) : pas de clé API — calcul local
# Agent 4 (Rédacteur) : utilise ANTHROPIC_API_KEY (socle commun)
# Agent 5 (Suiveur) : utilise GMAIL_* (Agent 2)
# ══════════════════════════════════════════════
#          AGENT 6 — NURTUREUR
# ══════════════════════════════════════════════
NURTUREUR_ENABLED=true
NURTUREUR_MAX_EMAILS_PER_WEEK=2              # Max emails nurture par prospect par semaine
NURTUREUR_MIN_DAYS_BETWEEN_EMAILS=3          # Min jours entre 2 emails nurture
NURTUREUR_SUNSET_DAYS=180                    # Jours avant sunset RGPD
NURTUREUR_RE_ENGAGEMENT_DAYS=60              # Jours d'inactivité avant re-engagement
NURTUREUR_RESCORE_THRESHOLD=75               # Score combiné pour handoff HOT
# Utilise ANTHROPIC_API_KEY (socle) + GMAIL_* (Agent 5)

# ══════════════════════════════════════════════
#          AGENT 7 — ANALYSTE
# ══════════════════════════════════════════════
ANALYSTE_ENABLED=true

# ──────────── Crons ────────────
ANALYSTE_SNAPSHOT_CRON=30 21 * * *              # 21:30 snapshot quotidien
ANALYSTE_ANOMALY_CRON=45 21 * * *               # 21:45 détection anomalies
ANALYSTE_DIGEST_CRON=0 22 * * *                 # 22:00 digest quotidien
ANALYSTE_WEEKLY_CRON=0 9 * * 1                  # Lundi 09:00 rapport hebdo
ANALYSTE_RECOMMANDATIONS_CRON=30 9 * * 1        # Lundi 09:30 recommandations
ANALYSTE_MONTHLY_CRON=0 8 1 * *                 # 1er du mois rapport mensuel

# ──────────── Seuils anomalies ────────────
ANALYSTE_ZSCORE_WARNING=1.5                     # z-score seuil WARNING
ANALYSTE_ZSCORE_CRITICAL=2.5                    # z-score seuil CRITICAL

# ──────────── Slack integration ────────────
# SLACK_WEBHOOK_URL déjà défini dans le socle commun
SLACK_CHANNEL_METRICS=#pipeline-metrics         # Canal pour digests et rapports
SLACK_CHANNEL_ALERTS=#alerts-critical           # Canal pour alertes critiques
SLACK_JONATHAN_ID=                              # Slack user ID pour DM critiques

# ──────────── Rapports ────────────
ANALYSTE_REPORT_EMAIL=jonathan@axiom-marketing.fr  # Email pour rapports
ANALYSTE_MONTHLY_TARGET_EUR=50000               # Objectif revenue mensuel (forecasting)

# ──────────── Objectifs Phase 1 ────────────
ANALYSTE_TARGET_REPLY_RATE=5                    # % reply rate objectif
ANALYSTE_TARGET_BOUNCE_RATE_MAX=2               # % bounce rate max
ANALYSTE_TARGET_DEALS_WEEK=4                    # Deals/semaine objectif
ANALYSTE_TARGET_CAC_MAX=500                     # EUR CAC max

# Utilise ANTHROPIC_API_KEY (socle) pour Claude Sonnet (rapports + recommandations)
# Utilise GMAIL_* (Agent 5) pour envoi rapports email
# Metabase : self-hosted Docker, connecté à PostgreSQL (pas de clé API)

# ══════════════════════════════════════════════
#          AGENT 8 — DEALMAKER
# ══════════════════════════════════════════════
DEALMAKER_ENABLED=true

# ──────────── Yousign API V3 (Signature électronique) ────────────
# Inscription : https://yousign.com — Plan Plus 28€/mois (API V3, signatures illimitées)
YOUSIGN_API_KEY=                                # API key Yousign
YOUSIGN_WEBHOOK_SECRET=                         # Secret HMAC pour validation webhooks
YOUSIGN_SANDBOX=true                            # true = sandbox (staging), false = production
# IPs webhooks à whitelister : 57.130.41.144/28, 51.38.96.112/28, 5.39.7.128/28

# ──────────── PDF Generation (Puppeteer) ────────────
# Puppeteer : self-hosted, pas de clé API (0€)
DEVIS_PDF_STORAGE_PATH=/tmp/devis               # Stockage local des PDFs générés
DEVIS_TRACKING_BASE_URL=https://t.axiom-marketing.fr  # Base URL pixel tracking ouverture devis

# ──────────── Pipeline CRM ────────────
DEALMAKER_TIMEOUT_DAYS=45                       # Jours avant auto-PERDU (timeout inaction)
DEALMAKER_FOLLOW_UP_J3=3                        # 1ère relance : vérification réception
DEALMAKER_FOLLOW_UP_J7=7                        # 2ème relance : angle valeur
DEALMAKER_FOLLOW_UP_J14=14                      # 3ème relance : breakup email
DEALMAKER_ENGAGEMENT_THRESHOLD=25               # Score engagement pour escalade Jonathan
DEALMAKER_READY_TO_SIGN_THRESHOLD=75            # Score engagement "Ready to Sign"

# ──────────── Slack notifications ────────────
SLACK_CHANNEL_DEALS=#deals                      # Canal pour les notifications deals
# SLACK_WEBHOOK_URL et SLACK_JONATHAN_ID déjà définis dans Agent 7

# Utilise ANTHROPIC_API_KEY (socle) pour Claude Sonnet (scope analysis + objection classification)
# Utilise GMAIL_* (Agent 5) pour envoi emails (devis + relances)

# ══════════════════════════════════════════════
#          AGENT 9 — APPELS D'OFFRES
# ══════════════════════════════════════════════
APPELS_OFFRES_ENABLED=true

# ──────────── PyMuPDF / PDF extraction ────────────
# ATTENTION : CVE-2026-0006 (CVSS 9.8) → exécuter UNIQUEMENT dans Docker sandbox
PYMUPDF_DOCKER_IMAGE=pymupdf-sandbox:latest     # Image Docker dédiée isolation
PYMUPDF_TIMEOUT_MS=120000                        # Timeout extraction PDF (2 min)
DCE_MAX_PAGES=500                                # Max pages par DCE
DCE_STORAGE_PATH=/data/marches-publics           # Stockage DCE et dossiers AO

# ──────────── Crons surveillance ────────────
APPELS_OFFRES_DEADLINE_CHECK_CRON=0 8 * * *     # Check deadlines quotidien 8h
APPELS_OFFRES_MONITEUR_CRON=0 6,14 * * *        # Surveillance résultats 2x/jour

# ──────────── Slack notifications ────────────
SLACK_CHANNEL_MARCHES=#marches-publics           # Canal pour notifications AO

# ──────────── Scoring GO/NO-GO ────────────
APPELS_OFFRES_GO_THRESHOLD=70                    # Score min pour GO automatique
APPELS_OFFRES_POSSIBLE_THRESHOLD=50              # Score min pour POSSIBLE (review Jonathan)

# Utilise ANTHROPIC_API_KEY (socle) pour Claude (analyse DCE, mémoire, scoring)
# Utilise BOAMP_API_URL + DECP_API_URL (Agent 1b) pour surveillance marchés
# Utilise SLACK_WEBHOOK_URL (socle) pour notifications Jonathan

# Agent 10 (CSM) : utilise GMAIL_* + ANTHROPIC_API_KEY

# ══════════════════════════════════════════════
#          AGENT 10 — CSM (Customer Success Manager)
# ══════════════════════════════════════════════
CSM_ENABLED=true

# ──────────── 10a Onboarding ────────────
ONBOARDING_KICKOFF_DELAY_DAYS=2              # Délai avant kickoff post-signature (jours)
ONBOARDING_TTV_ALERT_DAYS=14                 # Alerte si pas de Time-to-Value sous N jours
ONBOARDING_RISK_SILENCE_DAYS=5               # Silence avant risque onboarding (jours)

# ──────────── 10c Health Score + Churn ────────────
HEALTH_SCORE_CRON=0 8 * * *                  # Cron calcul health score quotidien
HEALTH_SCORE_GREEN_THRESHOLD=80              # Score >= 80 → GREEN
HEALTH_SCORE_YELLOW_THRESHOLD=60             # Score >= 60 → YELLOW
HEALTH_SCORE_ORANGE_THRESHOLD=50             # Score >= 50 → ORANGE
HEALTH_SCORE_DARK_ORANGE_THRESHOLD=30        # Score >= 30 → DARK_ORANGE (< 30 → RED)
CHURN_SILENCE_DAYS=60                        # Silence N jours → risque churn
CHURN_CRITICAL_SILENCE_DAYS=120              # Silence N jours → risque churn critique

# ──────────── 10c NPS / CSAT (Typeform) ────────────
NPS_POST_DELIVERY_DELAY_DAYS=30              # Délai envoi NPS post-livraison (jours)
NPS_QUARTERLY_CRON=0 9 1 */3 *              # Cron NPS trimestriel
# Typeform — Formulaires NPS + CSAT
# Inscription : https://typeform.com — plan Business ou API
TYPEFORM_API_KEY=
TYPEFORM_NPS_FORM_ID=
TYPEFORM_CSAT_FORM_ID=

# ──────────── 10b Upsell ────────────
UPSELL_MIN_SCORE=60                          # Score health min pour évaluation upsell
UPSELL_EVALUATION_DELAY_DAYS=60              # Délai avant 1ère évaluation upsell (jours)
UPSELL_COOLDOWN_DAYS=90                      # Cooldown entre 2 tentatives upsell (jours)

# ──────────── 10d Reviews ────────────
REVIEW_REQUEST_DELAY_DAYS=5                  # Délai post-NPS avant demande avis (jours)
REVIEW_REMINDER_1_DAYS=10                    # Délai 1er rappel avis (jours)
REVIEW_REMINDER_2_DAYS=15                    # Délai 2ème rappel avis (jours)
REVIEW_MIN_NPS=7                             # Score NPS min pour demander un avis

# URLs des plateformes d'avis
REVIEW_URL_GOOGLE=                           # URL profil Google Business
REVIEW_URL_TRUSTPILOT=                       # URL profil Trustpilot
REVIEW_URL_CLUTCH=                           # URL profil Clutch
REVIEW_URL_SORTLIST=                         # URL profil Sortlist
REVIEW_URL_LINKEDIN=                         # URL page LinkedIn entreprise

# ──────────── 10e Referral ────────────
REFERRAL_MIN_NPS=9                           # NPS min pour invitation parrainage (promoteurs)
REFERRAL_MIN_HEALTH=80                       # Health score min pour invitation parrainage
REFERRAL_MIN_DAYS=60                         # Ancienneté min client avant invitation (jours)

# Commissions parrainage (en %)
REFERRAL_COMMISSION_TIER1_PCT=20             # Commission tier 1 : 1er filleul (20%)
REFERRAL_COMMISSION_TIER2_PCT=15             # Commission tier 2 : 2ème filleul (15%)
REFERRAL_COMMISSION_TIER3_PCT=10             # Commission tier 3 : 3ème filleul+ (10%)
REFERRAL_RETENTION_BONUS_PCT=5               # Bonus rétention filleul à 12 mois (5%)

# Utilise ANTHROPIC_API_KEY (socle) pour Claude (analyse satisfaction, suggestions)
# Utilise GMAIL_* (Agent 5) pour envoi emails CSM
# Utilise SLACK_WEBHOOK_URL (socle) pour alertes churn critique
