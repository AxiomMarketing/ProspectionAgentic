generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ProspectStatus {
  raw
  enriched
  scored
  contacted
  replied
  meeting_booked
  deal_in_progress
  won
  lost
  nurturing
  blacklisted
  unsubscribed
  excluded
}

enum ChannelType {
  email
  linkedin
  phone
  sms
  postal
}

enum SequenceStepStatus {
  pending
  sent
  delivered
  opened
  clicked
  replied
  bounced
  failed
  skipped
}

enum ReplySentiment {
  positive
  negative
  neutral
  out_of_office
  unsubscribe_request
}

enum TenderStatus {
  DETECTED
  ANALYZING
  QUALIFIED
  GO
  IN_PROGRESS
  SUBMITTED
  WON
  LOST
  IGNORED
}

enum DealStage {
  QUALIFICATION
  DEVIS_CREE
  DEVIS_EN_CONSIDERATION
  NEGOCIATION
  SIGNATURE_EN_COURS
  GAGNE
  PERDU
}

enum AlertSeverity {
  info
  warning
  critical
}

enum ActionType {
  connection_request
  message
  inmail
  visit
  endorse
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Prospect {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName    String?
  lastName     String?
  fullName     String?
  email        String?  @unique
  emailVerified Boolean @default(false)
  phone        String?
  linkedinUrl  String?
  linkedinId   String?

  companyName     String?
  companySiren    String?
  companySize     String?
  companyRevenue  Float?
  companyWebsite  String?
  companyTechStack Json?

  jobTitle         String?
  seniorityLevel   String?
  isDecisionMaker  Boolean @default(false)

  status          ProspectStatus @default(raw)
  source          String?
  enrichmentData  Json?
  enrichedAt      DateTime?

  consentGiven Boolean  @default(false)
  consentDate  DateTime?
  rgpdErasedAt DateTime?

  scores                ProspectScore[]
  generatedMessages     GeneratedMessage[]
  emailSends            EmailSend[]
  linkedinActions       LinkedinAction[]
  sequences             ProspectSequence[]
  replyClassifications  ReplyClassification[]
  agentEvents           AgentEvent[]
  rawLead               RawLead?
  nurtureProspect       NurtureProspect?
  deals                 DealCrm[]
  bounceEvents          BounceEvent[]
  nurtureInteractions   NurtureInteraction[]
  customerContacts      Customer[]
  quotes                Quote[]
  touchpoints           Touchpoint[]

  @@index([status])
  @@index([email])
  @@index([companySiren])
  @@map("prospects")
}

model RawLead {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())

  source      String
  sourceId    String
  sourceUrl   String?
  rawData     Json
  processed   Boolean  @default(false)
  processedAt DateTime?

  prospectId    String?   @unique
  prospect      Prospect? @relation(fields: [prospectId], references: [id])

  errorMessage String?
  retryCount   Int     @default(0)

  @@unique([source, sourceId])
  @@index([processed])
  @@map("raw_leads")
}

model ProspectScore {
  id           String   @id @default(uuid())
  calculatedAt DateTime @default(now())

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  totalScore           Float
  firmographicScore    Float
  technographicScore   Float
  behavioralScore      Float
  engagementScore      Float
  intentScore          Float
  accessibilityScore   Float

  scoreBreakdown Json?
  segment        String?
  isLatest       Boolean @default(true)
  modelVersion   String  @default("1.0")

  @@index([prospectId, isLatest])
  @@map("prospect_scores")
}

model ScoringCoefficient {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name         String
  version      String
  isActive     Boolean @default(false)
  coefficients Json

  @@unique([name, version])
  @@map("scoring_coefficients")
}

model MessageTemplate {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name       String
  channel    ChannelType
  stepNumber Int
  subject    String?
  body       String
  variables  String[]

  variant   String?
  abGroupId String?

  totalSent    Int @default(0)
  totalOpened  Int @default(0)
  totalClicked Int @default(0)
  totalReplied Int @default(0)

  isActive   Boolean   @default(true)
  archivedAt DateTime?

  promptVersion String?
  language      String  @default("fr")

  generatedMessages GeneratedMessage[]

  @@map("message_templates")
}

model GeneratedMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  templateId String?
  template   MessageTemplate? @relation(fields: [templateId], references: [id])

  channel    ChannelType
  stepNumber Int
  subject    String?
  body       String

  modelUsed           String
  promptTokens        Int
  completionTokens    Int
  costEur             Float
  generationMs        Int
  personalizationData Json?
  langfuseTraceId     String?

  isApproved Boolean   @default(false)
  approvedBy String?
  approvedAt DateTime?

  emailSends            EmailSend[]
  replyClassifications  ReplyClassification[] @relation("GeneratedMessageClassifications")

  @@index([prospectId])
  @@map("generated_messages")
}

model EmailSend {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  messageId String?
  message   GeneratedMessage? @relation(fields: [messageId], references: [id])

  sequenceId String?
  sequence   ProspectSequence? @relation(fields: [sequenceId], references: [id])

  fromEmail String
  toEmail   String
  subject   String

  provider          String
  providerMessageId String?

  status SequenceStepStatus @default(pending)

  sentAt        DateTime?
  deliveredAt   DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  repliedAt     DateTime?
  bouncedAt     DateTime?
  bounceType    String?
  unsubscribedAt DateTime?

  openCount  Int @default(0)
  clickCount Int @default(0)

  trackingPixelId String?
  errorMessage    String?
  retryCount      Int     @default(0)

  replyClassifications ReplyClassification[]
  bounceEvents         BounceEvent[]

  @@index([prospectId])
  @@index([status])
  @@map("email_sends")
}

model LinkedinAction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  sequenceId String?
  sequence   ProspectSequence? @relation(fields: [sequenceId], references: [id])

  actionType  ActionType
  messageBody String?

  status SequenceStepStatus @default(pending)

  executedAt DateTime?
  repliedAt  DateTime?

  provider         String?
  providerActionId String?
  errorMessage     String?
  retryCount       Int     @default(0)

  replyClassifications ReplyClassification[]

  @@index([prospectId])
  @@map("linkedin_actions")
}

model ReplyClassification {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  generatedMessageId String?
  generatedMessage   GeneratedMessage? @relation("GeneratedMessageClassifications", fields: [generatedMessageId], references: [id])

  emailSendId String?
  emailSend   EmailSend? @relation(fields: [emailSendId], references: [id])

  linkedinActionId String?
  linkedinAction   LinkedinAction? @relation(fields: [linkedinActionId], references: [id])

  rawReply        String
  replyReceivedAt DateTime

  sentiment              ReplySentiment
  intent                 String?
  nextBestAction         String?
  suggestedResponse      String?
  classificationConfidence Float?

  modelUsed       String?
  costEur         Float?
  langfuseTraceId String?

  actionTaken   String?
  actionTakenAt DateTime?
  actionTakenBy String?

  @@index([prospectId])
  @@map("reply_classifications")
}

model ProspectSequence {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  name       String
  channel    ChannelType
  totalSteps Int
  currentStep Int @default(0)

  startedAt   DateTime?
  completedAt DateTime?
  pausedAt    DateTime?
  nextStepAt  DateTime?

  status        String @default("active")
  stoppedReason String?

  opensCount   Int @default(0)
  clicksCount  Int @default(0)
  repliesCount Int @default(0)

  emailSends      EmailSend[]
  linkedinActions LinkedinAction[]

  @@index([prospectId])
  @@map("prospect_sequences")
}

model BounceEvent {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  email      String
  prospectId String?
  prospect   Prospect? @relation(fields: [prospectId], references: [id])

  emailSendId String?
  emailSend   EmailSend? @relation(fields: [emailSendId], references: [id])

  bounceType      String
  bounceCode      String?
  bounceMessage   String?
  provider        String
  providerEventId String?

  @@index([email])
  @@map("bounce_events")
}

model NurtureProspect {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prospectId   String   @unique
  prospect     Prospect @relation(fields: [prospectId], references: [id])

  entryReason      String
  entryDate        DateTime @default(now())
  reactivationDate DateTime?
  status           String   @default("active")
  reactivatedAt    DateTime?
  exitReason       String?
  notes            String?
  tags             String[]

  sequenceType          String?
  currentStep           Int       @default(0)
  totalSteps            Int       @default(12)
  segment               String?
  scoringCategorie      String?
  journeyStage          String    @default("awareness")

  engagementScoreInitial  Float   @default(0)
  engagementScoreCurrent  Float   @default(0)
  lastScoreUpdate         DateTime?

  emailsNurtureSent       Int     @default(0)
  emailsOpened            Int     @default(0)
  emailsClicked           Int     @default(0)
  repliesReceived         Int     @default(0)
  contentDownloaded       Int     @default(0)
  consecutiveUnopened     Int     @default(0)

  nextEmailScheduledAt    DateTime?
  nextRescoreAt           DateTime?
  lastInteractionAt       DateTime?
  lastEmailSentAt         DateTime?
  inactiveSince           DateTime?

  consentBasis            String   @default("legitimate_interest")
  optOutAt                DateTime?
  dataRetentionUntil      DateTime?

  interactions NurtureInteraction[]

  @@map("nurture_prospects")
}

model NurtureInteraction {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  nurtureId String
  nurture   NurtureProspect @relation(fields: [nurtureId], references: [id])

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  interactionType String
  channel         ChannelType
  contentTitle    String?
  contentUrl      String?

  opened  Boolean @default(false)
  clicked Boolean @default(false)
  replied Boolean @default(false)

  replySentiment ReplySentiment?

  scoreDelta    Float?
  scoreAfter    Float?
  details       Json?

  @@index([prospectId])
  @@index([nurtureId])
  @@map("nurture_interactions")
}

model DealCrm {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  title             String
  stage             DealStage @default(QUALIFICATION)
  amountEur         Float?
  probability       Float?
  expectedCloseDate DateTime?
  closedAt          DateTime?
  wonReason         String?
  lostReason        String?
  lostAt            DateTime?
  ownerEmail        String?
  quoteId           String?
  tenderId          String?
  stageHistory      Json?

  devisId              String?
  devisUrl             String?
  devisEnvoyeAt        DateTime?
  trackingId           String?
  yousignRequestId     String?
  yousignDocumentId    String?
  yousignSignerId      String?
  contratEnvoyeAt      DateTime?
  contratSigneUrl      String?
  dateSignature        DateTime?
  nbRelances           Int       @default(0)
  derniereRelanceAt    DateTime?
  derniereObjection    String?
  rdvNotes             Json?
  typeProjet           String?
  tierRecommande       String?
  tierFinal            String?
  segment              String?
  canalPrincipal       String?

  quote           Quote?
  engagementScore EngagementScore?
  activities      DealActivity[]

  @@index([stage])
  @@index([prospectId])
  @@map("deals_crm")
}

model Quote {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dealId String  @unique
  deal   DealCrm @relation(fields: [dealId], references: [id])

  prospectId String
  prospect   Prospect @relation(fields: [prospectId], references: [id])

  quoteNumber  String  @unique
  title        String
  amountHtEur  Float
  tvaRate      Float   @default(0.20)
  amountTtcEur Float?
  lineItems    Json
  validityDays Int     @default(30)
  expiresAt    DateTime?
  notes        String?
  status       String  @default("draft")

  yousignProcedureId  String?
  signedAt            DateTime?
  signedDocumentUrl   String?
  pdfUrl              String?
  pdfGeneratedAt      DateTime?

  @@map("quotes")
}

model EngagementScore {
  id          String   @id @default(uuid())
  dealId      String   @unique
  deal        DealCrm  @relation(fields: [dealId], references: [id])
  score       Int      @default(0)
  signals     Json     @default("[]")
  lastUpdated DateTime @default(now())
  @@map("engagement_scores")
}

model DealActivity {
  id              String   @id @default(uuid())
  dealId          String
  deal            DealCrm  @relation(fields: [dealId], references: [id])
  type            String
  step            Int?
  engagementDelta Int?
  details         Json?
  createdAt       DateTime @default(now())
  @@index([dealId])
  @@map("deal_activities")
}

model DevisTracking {
  id           String      @id @default(uuid())
  devisId      String
  pdfUrl       String
  opens        Int         @default(0)
  lastOpenedAt DateTime?
  createdAt    DateTime    @default(now())
  trackingOpens DevisOpen[]
  @@map("devis_tracking")
}

model DevisOpen {
  id         String        @id @default(uuid())
  trackingId String
  tracking   DevisTracking @relation(fields: [trackingId], references: [id])
  openedAt   DateTime      @default(now())
  ipAddress  String?
  userAgent  String?
  @@index([trackingId])
  @@map("devis_opens")
}

model WebhookEvent {
  eventId     String   @id
  processedAt DateTime @default(now())
  @@map("webhook_events")
}

model PublicTender {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source    String
  sourceId  String
  sourceUrl String?

  title       String
  description String?

  buyerName  String?
  buyerSiren String?

  publicationDate  DateTime?
  deadlineDate     DateTime?
  estimatedAmount  Float?
  estimatedBudget  Float?

  cpvCodes         String[]
  departement      String?

  dceFitScore      Float?
  dceAnalyzed      Boolean @default(false)
  dceAnalysisResult Json?
  langfuseTraceId  String?

  status TenderStatus @default(DETECTED)

  aoAnalyse AoAnalyse?

  @@unique([source, sourceId])
  @@index([status])
  @@index([deadlineDate])
  @@map("public_tenders")
}

model AoAnalyse {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenderId String      @unique
  tender   PublicTender @relation(fields: [tenderId], references: [id])

  status          String  @default("pending")
  currentStep     String?
  errorMessage    String?

  scoreTotal      Float?
  scorePertinence Float?
  scoreCompetence Float?
  scoreBudget     Float?
  scoreConcurrence Float?
  decision        String?
  decisionReason  String?

  dceRawText      String?
  dcePages        Int?
  langfuseTraceId String?

  exigences       AoExigence[]
  questions       AoQuestion[]
  dossierAdmin    AoDossierAdmin?
  offreFinanciere AoOffreFinanciere?
  memoireTechnique AoMemoireTechnique?
  controleQa      AoControleQa?

  @@index([tenderId])
  @@index([status])
  @@map("ao_analyses")
}

model AoExigence {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  analyseId String
  analyse   AoAnalyse @relation(fields: [analyseId], references: [id])

  type        String
  description String
  mandatory   Boolean @default(true)
  met         Boolean?
  comment     String?

  @@index([analyseId])
  @@map("ao_exigences")
}

model AoQuestion {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  analyseId String
  analyse   AoAnalyse @relation(fields: [analyseId], references: [id])

  question    String
  category    String?
  priority    Int     @default(5)
  answer      String?
  answeredAt  DateTime?

  @@index([analyseId])
  @@map("ao_questions")
}

model AoDossierAdmin {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyseId String    @unique
  analyse   AoAnalyse @relation(fields: [analyseId], references: [id])

  status          String @default("pending")
  dc1Generated    Boolean @default(false)
  dc2Generated    Boolean @default(false)
  kbisChecked     Boolean @default(false)
  assuranceChecked Boolean @default(false)
  referencesAdded Boolean @default(false)

  documents Json?
  notes     String?

  @@map("ao_dossiers_admin")
}

model AoOffreFinanciere {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyseId String    @unique
  analyse   AoAnalyse @relation(fields: [analyseId], references: [id])

  status           String @default("pending")
  montantHtEur     Float?
  montantTtcEur    Float?
  tauxTva          Float  @default(0.20)
  margeEstimee     Float?
  chargeJours      Float?
  tauxJournalier   Float?
  decomposition    Json?
  variantes        Json?
  notes            String?

  @@map("ao_offres_financieres")
}

model AoMemoireTechnique {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyseId String    @unique
  analyse   AoAnalyse @relation(fields: [analyseId], references: [id])

  status          String @default("pending")
  approche        String?
  methodologie    String?
  planningJson    Json?
  equipeJson      Json?
  referencesJson  Json?
  differenciants  String?
  wordCount       Int?
  aiScoreRisk     Float?
  humanizedAt     DateTime?
  pdfUrl          String?
  langfuseTraceId String?

  @@map("ao_memoires_techniques")
}

model AoControleQa {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analyseId String    @unique
  analyse   AoAnalyse @relation(fields: [analyseId], references: [id])

  status            String @default("pending")
  checksJson        Json?
  errorsFound       Int    @default(0)
  warningsFound     Int    @default(0)
  approved          Boolean @default(false)
  approvedAt        DateTime?
  rejectionReason   String?
  langfuseTraceId   String?

  @@map("ao_controles_qa")
}

model Customer {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyName String
  siren       String? @unique
  legalForm   String?

  primaryContactId String?
  primaryContact   Prospect? @relation(fields: [primaryContactId], references: [id])

  contractStartDate DateTime?
  contractEndDate   DateTime?
  mrrEur            Float     @default(0)
  plan              String?
  status            String    @default("active")
  churnedAt         DateTime?
  churnReason       String?
  externalCrmId     String?
  notes             String?

  typeProjet            String?
  tier                  String?
  scopeDetaille         Json?
  conditionsPaiement    String?
  notesVente            String?
  dealCycleDays         Int?
  engagementScoreFinal  Float?

  healthScores          CustomerHealthScore[]
  deals                 DealCrm[]
  onboardingSteps       OnboardingStep[]
  onboardingRisks       OnboardingRisk[]
  upsellOpportunities   UpsellOpportunity[]
  reviewRequests        ReviewRequest[]
  referralProgram       ReferralProgram?
  npsSurveys            NpsSurvey[]
  churnSignals          ChurnSignal[]
  projectMilestones     ProjectMilestone[]
  renewalOpportunities  RenewalOpportunity[]

  @@index([status])
  @@index([typeProjet])
  @@map("customers")
}

model CustomerHealthScore {
  id           String   @id @default(uuid())
  calculatedAt DateTime @default(now())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  healthScore     Float
  healthLabel     String?
  usageScore      Float?
  supportScore    Float?
  financialScore  Float?
  engagementScore Float?
  npsScore        Float?
  signals         Json?
  isLatest        Boolean @default(true)

  @@index([customerId, isLatest])
  @@map("customer_health_scores")
}

model MetriquesDaily {
  id              String   @id @default(uuid())
  dateSnapshot    DateTime @unique @map("date_snapshot")

  // Agent 1: Veilleur
  veilleurLeadsBruts        Int     @default(0) @map("veilleur_leads_bruts")
  veilleurLeadsLinkedin     Int     @default(0) @map("veilleur_leads_linkedin")
  veilleurLeadsMarches      Int     @default(0) @map("veilleur_leads_marches")
  veilleurLeadsWeb          Int     @default(0) @map("veilleur_leads_web")
  veilleurLeadsJobboards    Int     @default(0) @map("veilleur_leads_jobboards")
  veilleurLeadsQualifies    Int     @default(0) @map("veilleur_leads_qualifies")
  veilleurPreScoreMoyen     Float   @default(0) @map("veilleur_pre_score_moyen")
  veilleurTauxDeduplication Float   @default(0) @map("veilleur_taux_deduplication")
  veilleurCoutApiEur        Float   @default(0) @map("veilleur_cout_api_eur")

  // Agent 2: Enrichisseur
  enrichisseurProspectsTraites    Int     @default(0) @map("enrichisseur_prospects_traites")
  enrichisseurEmailsTrouves      Int     @default(0) @map("enrichisseur_emails_trouves")
  enrichisseurEmailsNonTrouves   Int     @default(0) @map("enrichisseur_emails_non_trouves")
  enrichisseurTauxEnrichissement Float   @default(0) @map("enrichisseur_taux_enrichissement")
  enrichisseurTauxEmailValide    Float   @default(0) @map("enrichisseur_taux_email_valide")
  enrichisseurTempsMoyenMs       Int     @default(0) @map("enrichisseur_temps_moyen_ms")
  enrichisseurCoutApiEur         Float   @default(0) @map("enrichisseur_cout_api_eur")

  // Agent 3: Scoreur
  scoreurProspectsScores     Int     @default(0) @map("scoreur_prospects_scores")
  scoreurNbHot              Int     @default(0) @map("scoreur_nb_hot")
  scoreurNbWarm             Int     @default(0) @map("scoreur_nb_warm")
  scoreurNbCold             Int     @default(0) @map("scoreur_nb_cold")
  scoreurNbDisqualifie      Int     @default(0) @map("scoreur_nb_disqualifie")
  scoreurScoreMoyen         Float   @default(0) @map("scoreur_score_moyen")
  scoreurPctHot             Float   @default(0) @map("scoreur_pct_hot")
  scoreurPctWarm            Float   @default(0) @map("scoreur_pct_warm")
  scoreurPctCold            Float   @default(0) @map("scoreur_pct_cold")
  scoreurPctDisqualifie     Float   @default(0) @map("scoreur_pct_disqualifie")
  scoreurReclassifications  Int     @default(0) @map("scoreur_reclassifications")

  // Agent 4: Redacteur
  redacteurMessagesGeneres          Int     @default(0) @map("redacteur_messages_generes")
  redacteurCoutGenerationEur        Float   @default(0) @map("redacteur_cout_generation_eur")
  redacteurTempsMoyenGenerationMs   Int     @default(0) @map("redacteur_temps_moyen_generation_ms")
